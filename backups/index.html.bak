<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" href="./assets/img/velocityx-logo.svg">
<title>Jack Travels — Desire to Wander, Excitement & Global Exploration</title>

<meta name="description" content="Join Jack Travels: carefully selected trips, travel plans, and top-tier adventure opportunities for adventurers.">
<meta property="og:title" content="Jack Travels — Worldwide Trips & Cultural Voyages">
<meta property="og:description" content="Discover our full trip catalog, itinerary collection, and planned adventures through Jack Travels.">
<meta property="og:type" content="website">
<meta property="og:image" content="./assets/img/velocityx-logo.svg">

<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="Jack Travels — Adventure Refined">
<meta name="twitter:description" content="Discover amazing places, professional travel organization, and expedition tales with Jack Travels—extraordinary encounters for each traveler.">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">

<link rel="stylesheet" href="assets/css/style.css" />

<!-- ================= MOBILE NAV CSS ================= -->
<style>
.nav-toggle{
  display:none;
  background:none;
  border:none;
  font-size:26px;
  cursor:pointer;
}

/* Desktop */
.menu{
  display:flex;
  gap:18px;
}

/* Mobile */
@media (max-width: 900px){

  .nav-toggle{
    display:block;
    color:#fff;
  }

  .right{
    display:none;
  }

  .menu{
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    background: #0d1b2a;
    flex-direction: column;
    gap: 14px;
    padding: 20px;
    display: none;
    z-index: 9999;
  }

  .menu a{
    color:#fff;
    font-size:16px;
  }

  /* ACTIVE STATE */
  .menu.show{
    display:flex;
  }
}
</style>
</head>

<body>

<nav class="nav">
  <div class="container nav-inner">

    <a class="logo" href="index.html">
      <span>Jack Travels</span>
    </a>

    <!-- Toggle Button -->
    <button class="nav-toggle" id="navToggle">☰</button>

    <!-- Menu -->
    <div class="menu" id="navMenu">
      <a href="index.html" style="opacity:1;font-weight:800">Home</a>
      <a href="game.html">Discover</a>
      <a href="leaderboard.html">Places</a>
      <a href="about.html">About Us</a>
      <a href="blog.html">Guides</a>
      <a href="faq.html">FAQ</a>
      <a href="privacy.html">Privacy</a>
      <a href="terms.html">Terms</a>
    </div>

    <div class="right">
      <a class="btn" href="game.html">Plan Trip</a>
    </div>

  </div>
</nav>

<header class="hero">
  <div class="container grid">
    <div>
      <div class="badge">Jack Travels • Global Locations • Memorable Encounters</div>
      <h1>Jack Travels — Transformative Trips & Outstanding Thrills</h1>
      <p>
        Jack Travels designs personalized travel adventures, location knowledge, and exclusive trip packages
        for visitors from all walks of life. Review choices, book your plan, and traverse the planet with assurance.
      </p>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <a class="btn" href="game.html">Begin Discovery</a>
        <a class="btn ghost" href="blog.html" style="color: #000;">Thrill Tales</a>
      </div>
      <div class="kudos">
        <span class="pill">✈️ Adventure Entry</span>
        <span class="pill">🌍 Global Exploration</span>
        <span class="pill">🗺️ Personalized Routes</span>
      </div>
    </div>

    <div class="card">
      <div class="grid-2">
        <div class="card">
          <div class="stat">
            <div class="n" >75+</div>
            <div class="t" style="color: #fff;">Locations Showcased</div>
          </div>
        </div>
        <div class="card">
          <div class="stat">
            <div class="n">5000+</div>
            <div class="t" style="color: #fff;">Happy Explorers</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<section class="section container">
  <h2>Reasons to Select Jack Travels</h2>
  <p style="max-width:720px;margin:0 auto 32px;opacity:0.8">
    Jack Travels combines individualized trips, carefully chosen locations, and life-altering discovery, building
    significant relationships and lasting memories through thoughtfully crafted adventures and world-altering excursions.
  </p>

  <div class="grid-2" style="margin-bottom:48px">
    <div class="card" style="color: #fff;">
      <h3>✓ All-Year Adventures</h3>
      <p>Organized trips available all year for various skill levels, from novice visitors to experienced travelers.</p>
    </div>

    <div class="card" style="color: #fff;">
      <h3>🌟 Iconic Routes</h3>
      <p>Renowned paths and premium launches drawing travelers from everywhere.</p>
    </div>

    <div class="card" style="color: #fff;">
      <h3>🐟 Cultural Dive</h3>
      <p>Hands-on sessions and intercultural education led by local travel experts.</p>
    </div>

    <div class="card" style="color: #fff;">
      <h3>🎉 Tailored Selections</h3>
      <p>Customized trip choices for special places and niche travel collaborations.</p>
    </div>
  </div>
</section>

<section id="contact" class="section container">
  <div class="card">
    <h2 style="color: #fff; text-align: center;">Start Your Journey Now</h2>

    <form id="contact-form" style="max-width:720px;margin:24px auto 0;text-align:left">
      <div class="form-row">
        <div>
          <label style="color: #fff;">Full Name</label>
          <input name="name" required placeholder="Your Full Name">
        </div>
        <div>
          <label style="color: #fff;">Email</label>
          <input name="email" required type="email" placeholder="name@email.com">
        </div>
      </div>

      <div style="height:12px"></div>

      <div>
        <label style="color: #fff;">Message</label>
        <textarea name="message" rows="4"></textarea>
      </div>

      <div style="height:18px"></div>
      <button class="btn" type="submit">Send Message</button>
    </form>
  </div>
</section>

<footer class="footer">
  <div class="container" style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap">
    <div>© 2026 Jack Travels. All rights reserved.</div>
    <div>
      <span class="badge">Jack Travels • Trips • Exploration</span>
    </div>
  </div>
</footer>

<script src="assets/js/main.js"></script>

<!-- ============ MOBILE NAV SCRIPT ============ -->
<script>
document.addEventListener("DOMContentLoaded", function(){

  const mobileToggleBtn = document.getElementById("navToggle");
  const mobileMenuBox  = document.getElementById("navMenu");

  if(!mobileToggleBtn || !mobileMenuBox) return;

  mobileToggleBtn.addEventListener("click", function(){
    mobileMenuBox.classList.toggle("show");
  });

  // auto-close after click
  mobileMenuBox.querySelectorAll("a").forEach(link=>{
    link.addEventListener("click", ()=>{
      mobileMenuBox.classList.remove("show");
    });
  });

});
</script>

</body>
</html>
